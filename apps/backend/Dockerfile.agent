FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

# git for clone/commit/push; ripgrep for fast grep; ast-grep for structural search;
# patch for applying unified diffs from the agent's patch_file tool.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ripgrep patch ca-certificates curl \
 && curl -L https://github.com/ast-grep/ast-grep/releases/latest/download/app-x86_64-unknown-linux-gnu.zip -o /tmp/ast-grep.zip \
 && apt-get install -y --no-install-recommends unzip \
 && unzip /tmp/ast-grep.zip -d /usr/local/bin/ \
 && chmod +x /usr/local/bin/ast-grep /usr/local/bin/sg 2>/dev/null || true \
 && rm /tmp/ast-grep.zip \
 && apt-get purge -y unzip curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev

COPY src/ ./src/

RUN mkdir -p /workspace

ENTRYPOINT ["/app/.venv/bin/python", "-m", "src.ai.runner"]
