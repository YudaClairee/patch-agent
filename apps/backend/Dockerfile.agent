FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev

COPY src/ ./src/

# rag_tools uses PersistentClient at .data/chromadb relative to WORKDIR (/app).
# The host runner mounts /app/.data as a writable tmpfs so the read-only rootfs is not violated.
# /workspace is also mounted as a writable tmpfs by the host runner.
RUN mkdir -p /app/.data/chromadb /workspace

ENTRYPOINT ["uv", "run", "python", "-m", "src.ai.runner"]
