# --- Database & Cache ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
REDIS_URL=redis://localhost:6379/0

# --- LLM (provider-agnostic; LiteLLM routes by model-id prefix) ---
# Examples:
#   openrouter/google/gemini-2.0-flash-001     (LLM_BASE_URL=https://openrouter.ai/api/v1)
#   openai/gpt-4o-mini                          (leave LLM_BASE_URL blank)
#   anthropic/claude-3-5-sonnet-20241022        (leave LLM_BASE_URL blank)
#   gemini/gemini-2.0-flash                     (leave LLM_BASE_URL blank)
#   groq/llama-3.3-70b-versatile                (leave LLM_BASE_URL blank)
LLM_MODEL_ID=openai/gpt-4o-mini
LLM_API_KEY=sk-...
LLM_BASE_URL=

# Legacy (still read as fallback if LLM_* are blank — safe to remove)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENAI_API_KEY=

# --- Observability (Langfuse, optional) ---
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# --- Session / Auth ---
SESSION_COOKIE_NAME=patch_session
SESSION_TTL_HOURS=168
ENVIRONMENT=development

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
FRONTEND_URL=http://localhost:3000

# --- Agent Sandbox (Docker) ---
DOCKER_AGENT_IMAGE=patch/agent:latest
AGENT_MEMORY_LIMIT=2g
AGENT_CPUS=1.0
AGENT_PIDS_LIMIT=512
AGENT_MAX_WALL_TIME_SEC=900
